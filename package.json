{
  "name": "german-nursing-pathway",
  "private": true,
  "scripts": {
    "dev": "npm run dev --prefix frontend",
    "dev:api": "cd backend && python -m uvicorn app.main:app --reload --port 8000",
    "dev:all": "concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev\"",
    "build": "npm run build --prefix frontend",
    "build:gh": "npm run build:gh --prefix frontend",
    "db:migrate": "cd backend && alembic upgrade head",
    "db:load-scholarships": "cd backend && python scripts/load_scholarships.py",
    "db:revision": "cd backend && alembic revision --autogenerate -m",
    "export:scholarships": "node scripts/export-scholarships.mjs",
    "lint": "npm run lint --prefix frontend",
    "format": "npm run format --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
