# Chat provider: openai | gemini
CHAT_PROVIDER=gemini

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Comma-separated browser origins (scheme + host, no trailing slash, no path)
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,https://germanursingpathway.com,https://www.germanursingpathway.com
# Optional: Vercel preview deploys (each branch gets a unique *.vercel.app host)
CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# Reload prompt .md files on every request (dev)
PROMPT_RELOAD=true

# Neon Postgres (register-interest leads, Phase 2 portal)
DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Apply schema (from backend/ with venv active):
#   pip install -r requirements.txt
#   alembic upgrade head

# Admin CMS (Bearer token for /api/admin/* and /admin UI login)
ADMIN_API_SECRET=change-me-long-random-string

# Portal email OTP + JWT session (scholarships API requires sign-in)
JWT_SECRET=change-me-long-random-string-different-from-admin
JWT_EXPIRE_MINUTES=10080
OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_REQUESTS_PER_HOUR=3
# For Gmail SMTP: use your Gmail address here and set SMTP_USER to the same address
OTP_EMAIL_FROM=German Nursing Pathway <you@gmail.com>
OTP_SUPPORT_EMAIL=support@yourdomain.com
PUBLIC_SITE_URL=https://www.germanursingpathway.com

# OTP email delivery — use SMTP (recommended) or Resend API (optional fallback)
# Gmail: smtp.gmail.com, port 587, SMTP_USE_TLS=true — use an App Password (not your login password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_USE_TLS=true
SMTP_USE_SSL=false
RESEND_API_KEY=
# Set true in production behind HTTPS (required when PORTAL_COOKIE_SAMESITE=none)
PORTAL_COOKIE_SECURE=false
# Use "none" when frontend and API are on different domains (e.g. Vercel + Render)
PORTAL_COOKIE_SAMESITE=lax

# --- Paystack (homepage program fee — card + M-Pesa) ---
# Keys: https://dashboard.paystack.com/#/settings/developers
# Local webhooks/callbacks need HTTPS — e.g. ngrok http 8000 → PAYSTACK_CALLBACK_BASE_URL
#   Webhook URL: {PAYSTACK_CALLBACK_BASE_URL}/api/payments/paystack/webhook
#   Browser callback: {PAYSTACK_CALLBACK_BASE_URL}/api/payments/paystack/callback
# Enable KES + Card + Mobile Money in Paystack dashboard.
#
# Full program fee (€1,550): set KES equivalent (update when FX changes):
#   PAYMENT_AMOUNT_KES = round(1550 * EUR_TO_KES_RATE)   e.g. 1550 * 152 ≈ 235600
PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_PUBLIC_KEY=pk_test_...
PAYSTACK_CALLBACK_BASE_URL=https://your-ngrok-or-api-host.example.com
PAYMENT_AMOUNT_KES=235600
PAYMENT_CURRENCY_LABEL=KES

# Learning Hub premium unlock (modules 2–11) — separate from program fee
LEARNING_HUB_AMOUNT_KES=3000
LEARNING_HUB_FREE_MODULE_ID=getting-started
