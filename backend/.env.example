# Chat provider: openai | gemini
CHAT_PROVIDER=gemini

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Comma-separated origins for CORS
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Reload prompt .md files on every request (dev)
PROMPT_RELOAD=true

# Neon Postgres (register-interest leads, Phase 2 portal)
DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Apply schema (from backend/ with venv active):
#   pip install -r requirements.txt
#   alembic upgrade head

# --- KCB Buni M-Pesa STK Push (Investment Breakdown payments) ---
# 1. Register: https://sandbox.buni.kcbgroup.com
# 2. Create app → Generate keys (consumer key + secret)
# 3. Subscribe to M-Pesa STK Push API in the dev portal
# 4. Local callbacks require HTTPS — e.g. ngrok http 8000 → set KCB_CALLBACK_BASE_URL
#    Callback hits: {KCB_CALLBACK_BASE_URL}/api/payments/callback
#
# Full program fee (€2,300): set KES equivalent here (update when FX changes):
#   PAYMENT_AMOUNT_KES = round(2300 * EUR_TO_KES_RATE)   e.g. 2300 * 152 ≈ 349600
KCB_CONSUMER_KEY=
KCB_CONSUMER_SECRET=
KCB_API_BASE=https://uat.buni.kcbgroup.com
KCB_ORG_SHORT_CODE=522522
KCB_SHARED_SHORT_CODE=true
KCB_ORG_PASS_KEY=
KCB_CALLBACK_BASE_URL=
PAYMENT_AMOUNT_KES=349600
PAYMENT_CURRENCY_LABEL=KES
